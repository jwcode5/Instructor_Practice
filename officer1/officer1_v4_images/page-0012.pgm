                   ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   ■■■■■■■■■■■■■■■■                                                                ■■■■■■■■■■■■■■■■                                                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   ■■■■■■■■■■■■■■■■                                                                ■■■■■■■■■■■■■■■■                                                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   ■■■■■■■■■■■■■■■■                                                                ■■■■■■■■■■■■■■■■                                                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   ■■■■■■■■■■■■■■■■                                                                ■■■■■■■■■■■■■■■■                                                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   ■■■■■■■■■■■■■■■■                                                                ■■■■■■■■■■■■■■■■                                                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   ■■■■■■■■■■■■■■■■                                                                ■■■■■■■■■■■■■■■■                                                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           ■■■■■■■■                                ■■■■■■■■■■■■■■■■                                                ■■■■■■■■                        ■■■■■■■■                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                        ■■■■■■■■                        ■■■■■■■■                                                                        ■■■■■■■■                                        ■■■■■■■■                        ■■■■■■■■                        ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   ■■■■■■■■                                ■■■■■■■■■■■■■■■■                                                ■■■■■■■■                        ■■■■■■■■                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                        ■■■■■■■■                        ■■■■■■■■                                                                        ■■■■■■■■                                        ■■■■■■■■                        ■■■■■■■■                        ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   ■■■■■■■■                                ■■■■■■■■■■■■■■■■                                                ■■■■■■■■                        ■■■■■■■■                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                        ■■■■■■■■                        ■■■■■■■■                                                                        ■■■■■■■■                                        ■■■■■■■■                        ■■■■■■■■                        ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   ■■■■■■■■                                ■■■■■■■■■■■■■■■■                                                ■■■■■■■■                        ■■■■■■■■                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                        ■■■■■■■■                        ■■■■■■■■                                                                        ■■■■■■■■                                        ■■■■■■■■                        ■■■■■■■■                        ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   ■■■■■■■■                                ■■■■■■■■■■■■■■■■                                                ■■■■■■■■                        ■■■■■■■■                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                        ■■■■■■■■                        ■■■■■■■■                                                                        ■■■■■■■■                                        ■■■■■■■■                        ■■■■■■■■                        ■■■■■■■■                    