                                                                                                                                                                                                                                                                                                          ■■■■■■■■■■■■■■■■                ■■■■■■■■                ■■■■■■■■                                                ■■■■■■■■                                                ■■■■■■■■■■■■■■■■                ■■■■■■■■        ■■■■■■■■■■■■■■■■                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           ■■■■■■■■■■■■■■■■                ■■■■■■■■                ■■■■■■■■                                                ■■■■■■■■                                                ■■■■■■■■■■■■■■■■                ■■■■■■■■        ■■■■■■■■■■■■■■■■                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           ■■■■■■■■■■■■■■■■                ■■■■■■■■                ■■■■■■■■                                                ■■■■■■■■                                                ■■■■■■■■■■■■■■■■                ■■■■■■■■        ■■■■■■■■■■■■■■■■                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           ■■■■■■■■■■■■■■■■                ■■■■■■■■                ■■■■■■■■                                                ■■■■■■■■                                                ■■■■■■■■■■■■■■■■                ■■■■■■■■        ■■■■■■■■■■■■■■■■                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           ■■■■■■■■■■■■■■■■                ■■■■■■■■                ■■■■■■■■                                                ■■■■■■■■                                                ■■■■■■■■■■■■■■■■                ■■■■■■■■        ■■■■■■■■■■■■■■■■                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                          