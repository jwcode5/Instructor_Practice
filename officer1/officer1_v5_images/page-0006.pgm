                                                                                                                                                                                                                                                                                                                                                                                                      ■■■■■■■■                                ■■■■■■■■■■■■■■■■                                                        ■■■■■■■■■■■■■■■■■■■■■■■■                                                                                                                                        ■■■■■■■■■■■■■■■■                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           ■■■■■■■■                                ■■■■■■■■■■■■■■■■                                                        ■■■■■■■■■■■■■■■■■■■■■■■■                                                                                                                                        ■■■■■■■■■■■■■■■■                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           ■■■■■■■■                                ■■■■■■■■■■■■■■■■                                                        ■■■■■■■■■■■■■■■■■■■■■■■■                                                                                                                                        ■■■■■■■■■■■■■■■■                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           ■■■■■■■■                                ■■■■■■■■■■■■■■■■                                                        ■■■■■■■■■■■■■■■■■■■■■■■■                                                                                                                                        ■■■■■■■■■■■■■■■■                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           ■■■■■■■■                                ■■■■■■■■■■■■■■■■                                                        ■■■■■■■■■■■■■■■■■■■■■■■■                                                                                                                                        ■■■■■■■■■■■■■■■■                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           ■■■■■■■■                                ■■■■■■■■■■■■■■■■                                                        ■■■■■■■■■■■■■■■■■■■■■■■■                                                                                                                                        ■■■■■■■■■■■■■■■■                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           ■■■■■■■■                                ■■■■■■■■■■■■■■■■                                                        ■■■■■■■■■■■■■■■■■■■■■■■■                                                                                                                                        ■■■■■■■■■■■■■■■■                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           ■■■■■■■■                                ■■■■■■■■■■■■■■■■                                                        ■■■■■■■■■■■■■■■■■■■■■■■■                                                                                                                                        ■■■■■■■■■■■■■■■■                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           Є√  їі¤                         ■■■■■■■■■■■■■■■■■■■■■■■■        ■■■■■■■■■■■■■■■■        ■■■■■■■■                                                                        ■■■■■■■■                                        ■■■■■■■■■■■■■■■■                                                        ■■■■■■■■                                        ■■■■■■■■                                ■■■■■■■■■■■■■■■■                                                                                                                ■■■■■■■■                                                                                                                                                                                                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   №   №Ї¤                         ■■■■■■■■■■■■■■■■■■■■■■■■        ■■■■■■■■■■■■■■■■        ■■■■■■■■                                                                        ■■■■■■■■                                        ■■■■■■■■■■■■■■■■                                                        ■■■■■■■■                                        ■■■■■■■■                                ■■■■■■■■■■■■■■■■                                                                                                                ■■■■■■■■                                                                                                                                                                                                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       √єЇ■                        ■■■■■■■■■■■■■■■■■■■■■■■■        ■■■■■■■■■■■■■■■■        ■■■■■■■■                                                                        ■■■■■■■■                                        ■■■■■■■■■■■■■■■■                                                        ■■■■■■■■                                        ■■■■■■■■                                ■■■■■■■■■■■■■■■■                                                                                                                ■■■■■■■■                                                                                                                                                                                                ■■■■■■■■                                                                                                                                                                                                                                    