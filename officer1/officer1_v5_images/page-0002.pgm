                                                                                      ■■■■■■■■                                                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   ■■■■■■■■                                                ■■■■■■■■                                ■■■■■■■■                ■■■■■■■■■■■■■■■■■■■■■■■■                                        ■■■■■■■■■■■■■■■■                        ■■■■■■■■                                                                                                                ■■■■■■■■                                                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   ■■■■■■■■                                                ■■■■■■■■                                ■■■■■■■■                ■■■■■■■■■■■■■■■■■■■■■■■■                                        ■■■■■■■■■■■■■■■■                        ■■■■■■■■                                                                                                                ■■■■■■■■                                                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   ■■■■■■■■                                                ■■■■■■■■                                ■■■■■■■■                ■■■■■■■■■■■■■■■■■■■■■■■■                                        ■■■■■■■■■■■■■■■■                        ■■■■■■■■                                                                                                                ■■■■■■■■                                                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   ■■■■■■■■                                                ■■■■■■■■                                ■■■■■■■■                ■■■■■■■■■■■■■■■■■■■■■■■■                                        ■■■■■■■■■■■■■■■■                        ■■■■■■■■                                                                                                                ■■■■■■■■                                                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              