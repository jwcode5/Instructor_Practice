                                                                                                                                                                                                                                                                                                                                                ■■■■■■■■                                                                        ■■■■■■■■■■■■■■■■        ■■■■■■■■                                                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   ■■■■■■■■                                                                        ■■■■■■■■■■■■■■■■        ■■■■■■■■                                                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   ■■■■■■■■                                                                        ■■■■■■■■■■■■■■■■        ■■■■■■■■                                                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   ■■■■■■■■                                                                        ■■■■■■■■■■■■■■■■        ■■■■■■■■                                                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   ■■■■■■■■                                                                        ■■■■■■■■■■■■■■■■        ■■■■■■■■                                                ■■■■■■■■                                                                                                                                                                                                                                                                                                                                                                                                            